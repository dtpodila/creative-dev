{
  "ConnectionStrings": {
    "DefaultConnection": "CONNECTION_STRING_HERE"
  },
    "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_RANDOM_32_CHAR_KEY_MIN",
    "Issuer": "PhoneBillManagerApi",
    "Audience": "PhoneBillManagerApp",
    "ExpiryHours": "24"
  },
  "FileStorage": {
    "UploadPath": "uploads/bills"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "allowed_origin_here" ]  //example-http://localhost:3000
  }
}
